<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <!--
    The IAIso C# port deliberately depends on no NuGet packages. JSON
    parsing uses System.Text.Json, crypto uses System.Security.Cryptography,
    and tests use a small in-tree runner. This config disables the public
    feed so dotnet doesn't attempt to fetch from nuget.org when restoring
    framework reference assemblies (which ship with the SDK locally).

    Remove this file if you want to add NuGet packages — the public feed
    will be picked up automatically.
  -->
  <packageSources>
    <clear />
  </packageSources>
</configuration>
