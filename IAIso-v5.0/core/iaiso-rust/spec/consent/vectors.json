{
  "_comment": "IAIso consent test vectors v1.0. See spec/consent/README.md. The HS256 key used for end-to-end vectors is given in `hs256_key_shared`. This is a fixed conformance key; NEVER use it in production.",
  "version": "1.0",
  "hs256_key_shared": "test_secret_do_not_use_in_production_this_is_for_conformance_vectors_only_deadbeef",

  "scope_match": [
    {"name": "exact_match",               "granted": ["tools.search"], "requested": "tools.search",        "expected": true},
    {"name": "prefix_at_segment_boundary","granted": ["tools"],        "requested": "tools.search",        "expected": true},
    {"name": "prefix_deep_nesting",       "granted": ["tools"],        "requested": "tools.a.b.c.d",       "expected": true},
    {"name": "granted_more_specific_than_requested","granted": ["tools.search.bulk"],"requested": "tools.search","expected": false},
    {"name": "different_root",            "granted": ["admin"],        "requested": "tools.search",        "expected": false},
    {"name": "partial_word_not_prefix",   "granted": ["tool"],         "requested": "tools.search",        "expected": false},
    {"name": "substring_not_boundary",    "granted": ["tools"],        "requested": "toolsbar",            "expected": false},
    {"name": "multiple_grants_one_matches","granted": ["billing", "tools"], "requested": "tools.search",   "expected": true},
    {"name": "empty_grants_never_match",  "granted": [],               "requested": "tools.search",        "expected": false},
    {"name": "case_sensitive_no_match",   "granted": ["Tools"],        "requested": "tools",               "expected": false},
    {"name": "dash_and_underscore_segments","granted": ["api-v2.user_read"],"requested": "api-v2.user_read","expected": true},
    {"name": "exact_single_segment",      "granted": ["admin"],        "requested": "admin",               "expected": true}
  ],

  "scope_match_errors": [
    {"name": "empty_requested_raises", "granted": ["tools"], "requested": "", "expect_error": "non-empty"}
  ],

