  "issue_and_verify_roundtrip": [
    {
      "name": "roundtrip_basic",
      "description": "Issue a token with the fixed key, then verify it. Tests that a fresh token round-trips.",
      "issue": {
        "subject": "roundtrip-user",
        "scopes": ["tools.search"],
        "ttl_seconds": 60,
        "execution_id": null,
        "metadata": null
      },
      "expected_after_issue": {
        "subject": "roundtrip-user",
        "scopes": ["tools.search"],
        "execution_id": null
      },
      "expected_after_verify_succeeds": true
    },
    {
      "name": "roundtrip_with_execution_binding",
      "description": "Issue bound, verify with matching exec. Expect success.",
      "issue": {
        "subject": "roundtrip-user",
        "scopes": ["tools.search", "tools.fetch"],
        "ttl_seconds": 60,
        "execution_id": "exec-roundtrip",
        "metadata": {"role": "admin"}
      },
      "verify_with_execution_id": "exec-roundtrip",
      "expected_after_issue": {
        "subject": "roundtrip-user",
        "scopes": ["tools.search", "tools.fetch"],
        "execution_id": "exec-roundtrip"
      },
      "expected_after_verify_succeeds": true
    }
  ]
}
