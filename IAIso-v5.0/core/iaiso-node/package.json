{
  "name": "@iaiso/core",
  "version": "0.3.0",
  "description": "IAIso — reference Node.js / TypeScript SDK for the IAIso bounded-agent-execution framework.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./conformance": {
      "types": "./dist/conformance/index.d.ts",
      "import": "./dist/conformance/index.js"
    }
  },
  "bin": {
    "iaiso": "./bin/iaiso.mjs",
    "iaiso-conformance": "./bin/iaiso-conformance.mjs"
  },
  "files": [
    "dist",
    "bin",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "conformance": "node --import tsx ./src/conformance/cli.ts ./spec",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "iaiso",
    "llm",
    "agent",
    "safety",
    "pressure",
    "consent",
    "audit"
  ],
  "author": "Roen Branham <roen@smarttasks.cloud>",
  "license": "Apache-2.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "jsonwebtoken": "^9.0.2"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^22.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  },
  "peerDependencies": {
    "@anthropic-ai/sdk": "^0.91.0",
    "@aws-sdk/client-bedrock-runtime": "^3.1036.0",
    "@google/generative-ai": "^0.24.1",
    "@langchain/core": "^1.1.41",
    "@mistralai/mistralai": "^2.2.1",
    "@opentelemetry/api": "^1.9.1",
    "cohere-ai": "^8.0.0",
    "ioredis": "^5.10.1",
    "jose": "^6.2.2",
    "js-yaml": "^4.1.1",
    "openai": "^6.34.0",
    "prom-client": "^15.1.3"
  }
}
